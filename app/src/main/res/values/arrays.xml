<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string-array name="xposed_scope">
        <!--
            "system" is the LSPosed magic scope that maps to the
            system_server process. Earlier versions used "android" here,
            which on most ROMs is just the framework's own android package
            (uid 1000 but NOT the same runtime as the server). With
            "android" the daemon never injected adbx into system_server,
            so AdbSystemHooks.hook() never ran. Pair the magic scope
            with com.android.settings so the SettingsHooks side keeps
            working for the developer-options entry-point taps.
        -->
        <item>system</item>
        <item>com.android.settings</item>
    </string-array>
</resources>
