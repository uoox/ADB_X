<?xml version="1.0" encoding="utf-8"?>
<!--
    Full-screen pairing manager. Three sections:
    1. Status — what we currently detect about an active pairing session
       (port + code + copy-able host:port command) or a hint to start one in
       Developer Options.
    2. Custom code — set a 6-8 digit pairing code that adbd will accept.
    3. Open developer options — quick action that drops the user into the
       Wireless Debugging pane so they can flip on "Pair device with
       pairing code". One tap from this app to start a session.

    Reached from:
      - Status tab → "Pairing code" shortcut
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/pairingToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/section_pairing_code" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Live pairing status -->
            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewElevatedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                android:id="@+id/cardPairingStatus">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_pairing_code"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <TextView
                        android:id="@+id/tvPairingStatusSub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:padding="12dp"
                        android:background="?attr/colorSurfaceVariant"
                        android:fontFamily="monospace"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                        tools:text="Pairing code 123456 — host: 5555
adb pair 192.168.1.8:5555 123456" />

                    <TextView
                        android:id="@+id/tvPairingHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="Tap 打开开发者选项 → 无线调试 → 使用配对码配对" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyPairCommand"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/pairing_copy_command"
                        app:icon="@drawable/ic_copy" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTriggerPair"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/pairing_trigger_now"
                        app:icon="@drawable/ic_pairing" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenDevOptions"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/pairing_open_dev_options"
                        app:icon="@drawable/ic_settings" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Custom code -->
            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewElevatedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_set_pairing_code"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="@string/pairing_set_hint" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNewCode"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="@string/dialog_pairing_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNewCode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:inputType="number"
                            android:maxLength="8" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/btn_set_pairing_code" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
