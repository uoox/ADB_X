<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/app_name"
            app:titleTextColor="@android:color/white"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <TextView
            style="@style/SectionTitle"
            android:text="@string/section_fixed_port" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swFixedPort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="启用固定端口" />

            <EditText
                android:id="@+id/etPort"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:hint="@string/hint_port"
                android:inputType="number"
                android:text="5555" />
        </LinearLayout>

        <Button
            android:id="@+id/btnApplyPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:text="@string/btn_apply_port" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:background="@color/divider" />

        <TextView
            style="@style/SectionTitle"
            android:text="@string/section_auto" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swAutoEnable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="@string/sw_auto_enable" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swAutoDisable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="@string/sw_auto_disable" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:background="@color/divider" />

        <TextView
            style="@style/SectionTitle"
            android:text="@string/section_wifi" />

        <Button
            android:id="@+id/btnRefreshWifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:text="@string/btn_refresh_wifi" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvWifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="300dp"
            android:nestedScrollingEnabled="false" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:background="@color/divider" />

        <TextView
            style="@style/SectionTitle"
            android:text="@string/section_status" />

        <Button
            android:id="@+id/btnPairingCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:text="@string/btn_pairing_code" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="monospace" />

    </LinearLayout>
</ScrollView>
